{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "afatmustafa/blade-hugeicons": "^2.0",
        "andreiio/blade-iconoir": "^4.5",
        "andreiio/blade-remix-icon": "^3.5",
        "awcodes/filament-sticky-header": "^4.0",
        "aymanalhattami/filament-slim-scrollbar": "^2.1",
        "bezhansalleh/filament-shield": "^4.0",
        "codeat3/blade-clarity-icons": "^1.9",
        "codeat3/blade-eos-icons": "^1.14",
        "codeat3/blade-fluentui-system-icons": "^1.33",
        "codeat3/blade-iconpark": "^1.6",
        "codeat3/blade-phosphor-icons": "^2.2",
        "codeat3/blade-rpg-awesome-icons": "^1.5",
        "eduard9969/blade-polaris-icons": "^2.6",
        "fakerphp/faker": "^1.23",
        "filament/filament": "^5.0",
        "filament/forms": "^5.0",
        "filament/spatie-laravel-settings-plugin": "^5.0",
        "jeffersongoncalves/filament-cep-field": "^3.0",
        "larabug/larabug": "^3.7",
        "laravel/framework": "^13.0",
        "laravel/tinker": "^3.0",
        "leandrocfe/filament-apex-charts": "^5.0",
        "leandrocfe/filament-ptbr-form-fields": "^5.0",
        "livewire/livewire": "^4.0",
        "owenvoke/blade-fontawesome": "^3.2",
        "psr/simple-cache": "^3.0",
        "pxlrbt/filament-environment-indicator": "^3.5",
        "secondnetwork/blade-tabler-icons": "^3.44",
        "spatie/laravel-cookie-consent": "^3.4",
        "stechstudio/filament-impersonate": "^5.5",
        "tapp/filament-auditing": "^4.0",
        "troccoli/blade-health-icons": "^6.0"
    },
    "require-dev": {
        "laravel/boost": "^2.4",
        "laravel/pint": "^1.29",
        "laravel/sail": "^1.46",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.9",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "files": [
            "app/Support/helpers.php"
        ],
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
